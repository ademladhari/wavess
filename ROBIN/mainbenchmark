_IMG_EXTS = {".png", ".jpg", ".jpeg", ".webp", ".bmp"}


def load_prompts(path: Path, n: int) -> list[str]:
    lines = [ln.strip() for ln in path.read_text(encoding="utf-8").splitlines() if ln.strip()]
    if not lines:
        raise ValueError(f"No prompts in {path}")
    if len(lines) < n:
        reps = (n + len(lines) - 1) // len(lines)
        lines = (lines * reps)[:n]
    return lines[:n]


def resolve_wm_path(path: Path | None) -> Path:
    if path is not None and path.is_file():
        return path
    if path is not None and path.is_dir():
        pts = sorted(path.rglob("*.pt"))
        if pts:
            return pts[-1]
    for base in (REPO_ROOT / "ckpts", REPO_ROOT):
        if base.is_dir():
            pts = sorted(base.rglob("*.pt"))
            if pts:
                return pts[-1]
    raise FileNotFoundError("No ROBIN checkpoint (.pt with opt_wm). Use --wm-path.")


def psnr_ssim_pil(ref: Image.Image, attacked: Image.Image) -> tuple[float, float]:
    b = attacked.resize(ref.size, Image.Resampling.LANCZOS) if attacked.size != ref.size else attacked
    a_np = np.asarray(ref, dtype=np.float64)
    b_np = np.asarray(b, dtype=np.float64)
    psnr_v = float(peak_signal_noise_ratio(a_np, b_np, data_range=255.0))
    ssim_v = float(structural_similarity(a_np, b_np, channel_axis=2, data_range=255.0))
    return psnr_v, ssim_v


def distance_to_score(distance: float) -> float:
    return float(np.clip(1.0 / (1.0 + float(distance)), 0.0, 1.0))


def score_to_distance(score: float) -> float:
    s = float(score)
    if s <= 0.0:
        return float("inf")
    return 1.0 / s - 1.0


def load_neg_scores(path: Path, n_images: int) -> tuple[np.ndarray, np.ndarray]:
    arr = np.load(path)
    if arr.ndim != 1:
        raise ValueError(f"Expected 1-D neg scores in {path}, got shape {arr.shape}")
    if arr.size < n_images:
        raise ValueError(f"{path} has {arr.size} scores but {n_images} image pairs requested")
    neg_scores = np.asarray(arr[:n_images], dtype=np.float64)
    neg_distances = np.asarray([score_to_distance(s) for s in neg_scores], dtype=np.float64)
    return neg_scores, neg_distances


def detection_auroc_and_tpr(
    pos: np.ndarray, neg: np.ndarray, fpr_target: float = 0.01
) -> tuple[float, float]:
    y_true = np.concatenate([np.zeros(neg.size, dtype=np.int32), np.ones(pos.size, dtype=np.int32)])
    y_score = np.concatenate([neg, pos])
    auroc = float(sk_metrics.roc_auc_score(y_true, y_score))
    fpr, tpr, _ = sk_metrics.roc_curve(y_true, y_score, pos_label=1)
    below = np.where(fpr < fpr_target)[0]
    tpr_at = float(tpr[below[-1]]) if below.size else float(tpr[0])
    return auroc, tpr_at


def build_wm_args() -> SimpleNamespace:
    return SimpleNamespace(
        w_seed=999999,
        w_channel=3,
        w_pattern="ring",
        w_mask_shape="circle",
        w_up_radius=30,
        w_low_radius=5,
        w_measurement="l1_complex",
        w_injection="complex",
        w_pattern_const=0.0,
    )


class RobinBenchmark:
    def __init__(
        self,
        *,
        model_id: str,
        wm_path: Path,
        device: str,
        image_length: int,
        guidance_scale: float,
        num_inference_steps: int,
        watermarking_steps: int,
        detect_steps: int,
        prompt: str,
    ) -> None:
        self.device = device
        self.image_length = image_length
        self.guidance_scale = guidance_scale
        self.num_inference_steps = num_inference_steps
        self.watermarking_steps = watermarking_steps
        self.detect_steps = detect_steps
        self.prompt_default = prompt
        self.args = build_wm_args()

        scheduler = DPMSolverMultistepScheduler.from_pretrained(model_id, subfolder="scheduler")
        self.pipe = InversableStableDiffusionPipeline.from_pretrained(
            model_id,
            scheduler=scheduler,
            torch_dtype=torch.float32,
            safety_checker=None,
            feature_extractor=None,
        ).to(device)

        ckpt = torch.load(wm_path, map_location="cpu")
        if "opt_wm" not in ckpt:
            raise KeyError(f"Checkpoint missing opt_wm: {wm_path}")
        self.opt_wm = ckpt["opt_wm"].to(device)
        self.opt_acond = ckpt.get("opt_acond")
        self.text_embeddings = self.pipe.get_text_embedding("")
        if self.opt_acond is not None:
            self.opt_acond = self.opt_acond.to(self.text_embeddings.dtype).to(device)

        init_latents = self.pipe.get_random_latents(height=image_length, width=image_length)
        self.wm_mask = get_watermarking_mask(init_latents, self.args, device)

    def _latents(self, seed: int) -> torch.Tensor:
        set_random_seed(seed)
        gen = torch.Generator(device=self.device).manual_seed(seed)
        return self.pipe.get_random_latents(
            height=self.image_length,
            width=self.image_length,
            generator=gen,
        )

    def generate_clean(self, prompt: str, seed: int) -> Image.Image:
        latents = self._latents(seed)
        out = self.pipe(
            prompt,
            num_images_per_prompt=1,
            guidance_scale=self.guidance_scale,
            num_inference_steps=self.num_inference_steps,
            height=self.image_length,
            width=self.image_length,
            latents=latents,
        )
        return out.images[0].convert("RGB")

    def generate_watermarked(self, prompt: str, seed: int) -> Image.Image:
        latents = self._latents(seed)
        out = self.pipe(
            prompt,
            num_images_per_prompt=1,
            guidance_scale=self.guidance_scale,
            num_inference_steps=self.num_inference_steps,
            height=self.image_length,
            width=self.image_length,
            latents=copy.deepcopy(latents),
            watermarking_mask=self.wm_mask,
            watermarking_steps=self.watermarking_steps,
            args=self.args,
            gt_patch=self.opt_wm,
            lguidance=self.guidance_scale,
            opt_acond=self.opt_acond,
        )
        return out.images[0].convert("RGB")

    def detect_distance(self, image: Image.Image) -> float:
        """Mean L1 distance in FFT ring mask vs opt_wm (lower = closer to key)."""
        img = (
            transform_img(image, target_size=self.image_length)
            .unsqueeze(0)
            .to(self.text_embeddings.dtype)
            .to(self.device)
        )
        image_latents = self.pipe.get_image_latents(img, sample=False)
        reversed_latents = self.pipe.forward_diffusion(
            latents=image_latents,
            text_embeddings=self.text_embeddings,
            guidance_scale=1.0,
            num_inference_steps=self.detect_steps,
        )
        rev_fft = torch.fft.fftshift(torch.fft.fft2(reversed_latents), dim=(-1, -2))
        target = self.opt_wm.to(rev_fft.dtype)
        return float(torch.abs(rev_fft[self.wm_mask] - target[self.wm_mask]).mean().item())

    def detect_score(self, image: Image.Image) -> float:
        return distance_to_score(self.detect_distance(image))


def list_images(root: Path) -> list[Path]:
    if not root.is_dir():
        raise FileNotFoundError(f"Image directory not found: {root}")
    paths = sorted(p for p in root.iterdir() if p.suffix.lower() in _IMG_EXTS)
    if not paths:
        raise FileNotFoundError(f"No images in {root}")
    return paths


def _image_index(name: str, prefix: str) -> int:
    m = re.match(rf"{re.escape(prefix)}(\d+)_", name)
    if not m:
        raise ValueError(f"Unexpected filename (expected {prefix}<idx>_...): {name}")
    return int(m.group(1))


def load_records_from_combined_dir(image_dir: Path, n_images: int | None) -> list[dict]:
    if not image_dir.is_dir():
        raise FileNotFoundError(f"Image directory not found: {image_dir}")
    wm_paths = sorted(
        (p for p in image_dir.iterdir() if p.name.startswith("wm_image_") and p.suffix.lower() in _IMG_EXTS),
        key=lambda p: _image_index(p.name, "wm_image_"),
    )
    clean_paths = sorted(
        (p for p in image_dir.iterdir() if p.name.startswith("clean_image_") and p.suffix.lower() in _IMG_EXTS),
        key=lambda p: _image_index(p.name, "clean_image_"),
    )
    if not wm_paths or not clean_paths:
        raise FileNotFoundError(f"Expected wm_image_* and clean_image_* in {image_dir}")
    n = min(len(wm_paths), len(clean_paths))
    if len(wm_paths) != len(clean_paths):
        print(
            f"Warning: found {len(wm_paths)} wm and {len(clean_paths)} clean images — using first {n}",
            flush=True,
        )
    if n_images is not None:
        n = min(n, n_images)
    records: list[dict] = []
    for i in range(n):
        wm_idx = _image_index(wm_paths[i].name, "wm_image_")
        clean_idx = _image_index(clean_paths[i].name, "clean_image_")
        if wm_idx != clean_idx:
            raise ValueError(
                f"Pair mismatch at slot {i}: {wm_paths[i].name} vs {clean_paths[i].name}"
            )
        records.append(
            {
                "prompt": "",
                "wm_pil": Image.open(wm_paths[i]).convert("RGB"),
                "clean_pil": Image.open(clean_paths[i]).convert("RGB"),
                "seed": wm_idx,
                "wm_path": str(wm_paths[i]),
                "clean_path": str(clean_paths[i]),
            }
        )
    return records


def load_records_from_dirs(wm_dir: Path, clean_dir: Path, n_images: int | None) -> list[dict]:
    wm_paths = list_images(wm_dir)
    clean_paths = list_images(clean_dir)
    n = min(len(wm_paths), len(clean_paths))
    if len(wm_paths) != len(clean_paths):
        print(
            f"Warning: wm_dir has {len(wm_paths)} images, clean_dir has {len(clean_paths)} — using first {n}",
            flush=True,
        )
    if n_images is not None:
        n = min(n, n_images)
    records: list[dict] = []
    for i in range(n):
        records.append(
            {
                "prompt": "",
                "wm_pil": Image.open(wm_paths[i]).convert("RGB"),
                "clean_pil": Image.open(clean_paths[i]).convert("RGB"),
                "seed": i,
                "wm_path": str(wm_paths[i]),
                "clean_path": str(clean_paths[i]),
            }
        )
    return records


def load_completed_rows(output_dir: Path) -> dict[str, dict]:
    csv_path = output_dir / "results.csv"
    if not csv_path.is_file():
        return {}
    with open(csv_path, newline="", encoding="utf-8") as f:
        return {row["attack"]: row for row in csv.DictReader(f)}


def write_results(
    output_dir: Path,
    rows_out: list[dict],
    *,
    model_id: str,
    wm_file: Path,
    n_images: int,
    seed: int,
    prompts_file: str,
    sanity_dist: float,
    mean_clean_distance: float,
) -> None:
    csv_path = output_dir / "results.csv"
    with open(csv_path, "w", newline="", encoding="utf-8") as f:
        w = csv.DictWriter(f, fieldnames=list(rows_out[0].keys()))
        w.writeheader()
        w.writerows(rows_out)

    summary = {
        "method": "robin",
        "implementation": "ROBIN/inverse_stable_diffusion.py",
        "generation_based": True,
        "detect_only": True,
        "model_id": model_id,
        "wm_path": str(wm_file),
        "n_images": n_images,
        "seed": seed,
        "prompts_file": prompts_file,
        "sanity_identity_distance": sanity_dist,
        "mean_clean_distance": mean_clean_distance,
        "attacks": rows_out,
    }
    with open(output_dir / "results.json", "w", encoding="utf-8") as f:
        json.dump(summary, f, indent=2)


def evaluate_records(
    bench: RobinBenchmark,
    records: list[dict],
    output_dir: Path,
    *,
    model_id: str,
    wm_file: Path,
    seed: int,
    prompts_file: str,
    neg_scores_path: Path | None = None,
    resume: bool = False,
    attacks: list[str] | None = None,
) -> list[dict]:
    output_dir.mkdir(parents=True, exist_ok=True)

    sanity_dist = bench.detect_distance(records[0]["wm_pil"])
    print(f"Sanity (image 0, no attack): fft_l1_distance={sanity_dist:.1f}", flush=True)

    if neg_scores_path is not None:
        neg_scores, neg_distances = load_neg_scores(neg_scores_path, len(records))
        mean_clean_distance = float(neg_distances.mean())
        print(
            f"Loaded {len(neg_scores)} negative scores from {neg_scores_path} "
            f"(mean clean L1 distance={mean_clean_distance:.1f})",
            flush=True,
        )
    else:
        neg_distances = np.asarray(
            [bench.detect_distance(rec["clean_pil"]) for rec in tqdm(records, desc="detect/negatives", unit="img")],
            dtype=np.float64,
        )
        mean_clean_distance = float(neg_distances.mean())
        neg_scores = np.asarray([distance_to_score(d) for d in neg_distances], dtype=np.float64)
        np.save(output_dir / "neg_scores.npy", neg_scores)
        np.save(output_dir / "neg_distances.npy", neg_distances)

    completed = load_completed_rows(output_dir) if resume else {}
    if completed:
        print(f"Resume: skipping {len(completed)} attack(s) already in results.csv", flush=True)

    attack_specs = ATTACKS
    if attacks:
        wanted = set(attacks)
        attack_specs = tuple(spec for spec in ATTACKS if spec.name in wanted)
        missing = wanted - {spec.name for spec in attack_specs}
        if missing:
            raise ValueError(f"Unknown attack(s): {', '.join(sorted(missing))}")

    rows_out: list[dict] = []
    for spec in attack_specs:
        if spec.name in completed:
            row = completed[spec.name]
            rows_out.append(row)
            print(f"  {spec.name}: skipped (resume)", flush=True)
            continue

        psnr_vals: list[float] = []
        ssim_vals: list[float] = []
        pos_scores: list[float] = []
        wm_distances: list[float] = []

        for i, rec in enumerate(tqdm(records, desc=f"robin/{spec.name}", unit="img")):
            attacked_pil = apply_attack_rgb(spec.name, rec["wm_pil"], seed=i)
            p, s = psnr_ssim_pil(rec["wm_pil"], attacked_pil)
            psnr_vals.append(p)
            ssim_vals.append(s)
            dist = bench.detect_distance(attacked_pil)
            wm_distances.append(dist)
            pos_scores.append(distance_to_score(dist))

        pos_arr = np.asarray(pos_scores, dtype=np.float64)
        auroc, tpr1 = detection_auroc_and_tpr(pos_arr, neg_scores)
        mean_wm_distance = float(np.mean(wm_distances))

        row = {
            "method": "robin",
            "detector": "ddim_invert_fft_l1",
            "attack": spec.name,
            "description": spec.description,
            "n_images": len(records),
            "mean_wm_distance": mean_wm_distance,
            "mean_clean_distance": mean_clean_distance,
            "distance_gap": float(mean_clean_distance - mean_wm_distance),
            "PSNR": float(np.mean(psnr_vals)),
            "SSIM": float(np.mean(ssim_vals)),
            "bit_accuracy": float("nan"),
            "AUROC": auroc,
            "TPR_at_1pct_FPR": tpr1,
        }
        rows_out.append(row)
        print(
            f"  {spec.name}: wm_dist={mean_wm_distance:.1f}  gap={row['distance_gap']:.1f}  "
            f"(clean_ref={mean_clean_distance:.1f})",
            flush=True,
        )
        write_results(
            output_dir,
            rows_out,
            model_id=model_id,
            wm_file=wm_file,
            n_images=len(records),
            seed=seed,
            prompts_file=prompts_file,
            sanity_dist=sanity_dist,
            mean_clean_distance=mean_clean_distance,
        )

    csv_path = output_dir / "results.csv"
    print(f"\nWrote {csv_path} ({len(rows_out)} attacks)", flush=True)
    return rows_out


def run_detect_only(
    output_dir: Path,
    *,
    wm_dir: Path | None,
    clean_dir: Path | None,
    image_dir: Path | None,
    n_images: int | None,
    neg_scores_path: Path | None,
    wm_path: Path,
    model_id: str,
    device: str,
    image_length: int,
    detect_steps: int,
    resume: bool,
    attacks: list[str] | None,
) -> list[dict]:
    wm_file = resolve_wm_path(wm_path)
    if image_dir is not None:
        records = load_records_from_combined_dir(image_dir, n_images)
        source = f"  images: {image_dir}"
    else:
        records = load_records_from_dirs(wm_dir, clean_dir, n_images)
        source = f"  wm:    {wm_dir}\n  clean: {clean_dir}"
    print(
        f"Detect-only on {len(records)} pairs from\n"
        f"{source}\n"
        f"(checkpoint={wm_file.name})…",
        flush=True,
    )
    bench = RobinBenchmark(
        model_id=model_id,
        wm_path=wm_file,
        device=device,
        image_length=image_length,
        guidance_scale=7.5,
        num_inference_steps=50,
        watermarking_steps=35,
        detect_steps=detect_steps,
        prompt="",
    )
    return evaluate_records(
        bench,
        records,
        output_dir,
        model_id=model_id,
        wm_file=wm_file,
        seed=0,
        prompts_file=f"image_dir={image_dir}" if image_dir else f"wm_dir={wm_dir}",
        neg_scores_path=neg_scores_path,
        resume=resume,
        attacks=attacks,
    )


def run(
    output_dir: Path,
    *,
    n_images: int,
    prompts_path: Path,
    wm_path: Path,
    model_id: str,
    seed: int,
    device: str,
    prompt: str,
    image_length: int,
    guidance_scale: float,
    num_inference_steps: int,
    watermarking_steps: int,
    detect_steps: int,
) -> list[dict]:
    output_dir.mkdir(parents=True, exist_ok=True)
    prompts = load_prompts(prompts_path, n_images)
    wm_file = resolve_wm_path(wm_path)

    bench = RobinBenchmark(
        model_id=model_id,
        wm_path=wm_file,
        device=device,
        image_length=image_length,
        guidance_scale=guidance_scale,
        num_inference_steps=num_inference_steps,
        watermarking_steps=watermarking_steps,
        detect_steps=detect_steps,
        prompt=prompt,
    )

    records: list[dict] = []
    print(
        f"Generating {n_images} watermarked + {n_images} clean images "
        f"(model={model_id}, wm={wm_file.name})…",
        flush=True,
    )
    for i in tqdm(range(n_images), desc="generate", unit="img"):
        gen_seed = seed + i
        text = prompts[i] if prompt == "per_image" else prompt
        wm_pil = bench.generate_watermarked(text, gen_seed)
        clean_pil = bench.generate_clean(text, gen_seed)
        records.append({"prompt": text, "wm_pil": wm_pil, "clean_pil": clean_pil, "seed": gen_seed})

    return evaluate_records(
        bench,
        records,
        output_dir,
        model_id=model_id,
        wm_file=wm_file,
        seed=seed,
        prompts_file=str(prompts_path),
    )


def main() -> int:
    default_prompts = REPO_ROOT / "prompts.txt"
    if not default_prompts.is_file():
        default_prompts = REPO_ROOT.parent / "tree-ring" / "prompts.txt"

    p = argparse.ArgumentParser(description="ROBIN standalone benchmark (WAVES attacks)")
    p.add_argument("--output", type=Path, default=REPO_ROOT / "outputs_benchmark")
    p.add_argument("--n-images", type=int, default=None, help="Cap image count (default: all for --detect-only, else 10)")
    p.add_argument("--prompts", type=Path, default=default_prompts)
    p.add_argument("--wm-path", type=Path, default=None, help="opt_wm checkpoint (default: latest in ckpts/)")
    p.add_argument("--model-id", default="sd2-community/stable-diffusion-2-1-base")
    p.add_argument("--seed", type=int, default=42)
    p.add_argument("--device", default="cuda" if torch.cuda.is_available() else "cpu")
    p.add_argument("--prompt", default="a photo", help='generation prompt, or "per_image" to use prompts file')
    p.add_argument("--image-length", type=int, default=512)
    p.add_argument("--guidance-scale", type=float, default=7.5)
    p.add_argument("--num-inference-steps", type=int, default=50)
    p.add_argument("--watermarking-steps", type=int, default=35)
    p.add_argument("--detect-steps", type=int, default=50)
    p.add_argument(
        "--detect-only",
        action="store_true",
        help="Skip generation; score existing image pairs from --wm-dir and --clean-dir",
    )
    p.add_argument("--wm-dir", type=Path, default=None, help="Watermarked PNGs (sorted filenames, paired with clean)")
    p.add_argument("--clean-dir", type=Path, default=None, help="Clean PNGs (same count/order as wm-dir)")
    p.add_argument(
        "--image-dir",
        type=Path,
        default=None,
        help="Single folder with wm_image_* and clean_image_* (alternative to --wm-dir/--clean-dir)",
    )
    p.add_argument(
        "--neg-scores",
        type=Path,
        default=None,
        help="Precomputed clean negative scores (.npy, length=n_images) — skips detect/negatives",
    )
    p.add_argument(
        "--resume",
        action="store_true",
        help="Skip attacks already present in output/results.csv",
    )
    p.add_argument(
        "--attacks",
        default=None,
        help="Comma-separated attack names to run (default: all 14)",
    )
    args = p.parse_args()
    attack_list = [a.strip() for a in args.attacks.split(",") if a.strip()] if args.attacks else None

    if args.detect_only:
        if args.image_dir:
            if args.wm_dir or args.clean_dir:
                p.error("Use either --image-dir or --wm-dir/--clean-dir, not both")
        elif not args.wm_dir or not args.clean_dir:
            p.error("--detect-only requires --image-dir or both --wm-dir and --clean-dir")
        run_detect_only(
            args.output,
            wm_dir=args.wm_dir,
            clean_dir=args.clean_dir,
            image_dir=args.image_dir,
            n_images=args.n_images,
            neg_scores_path=args.neg_scores,
            wm_path=args.wm_path,
            model_id=args.model_id,
            device=args.device,
            image_length=args.image_length,
            detect_steps=args.detect_steps,
            resume=args.resume,
            attacks=attack_list,
        )
    else:
        run(
            args.output,
            n_images=args.n_images if args.n_images is not None else 10,
            prompts_path=args.prompts,
            wm_path=args.wm_path,
            model_id=args.model_id,
            seed=args.seed,
            device=args.device,
            prompt=args.prompt,
            image_length=args.image_length,
            guidance_scale=args.guidance_scale,
            num_inference_steps=args.num_inference_steps,
            watermarking_steps=args.watermarking_steps,
            detect_steps=args.detect_steps,
        )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
